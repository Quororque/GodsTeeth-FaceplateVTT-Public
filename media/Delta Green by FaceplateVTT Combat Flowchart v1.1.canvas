		{"id":"5da381624c48cf4f","fromNode":"588b96406a1508bc","fromSide":"bottom","toNode":"aff3ddecb6383e5d","toSide":"top","label":"Stunned"},
		{"id":"0d021b1e7d4d0baa","fromNode":"aff3ddecb6383e5d","fromSide":"bottom","toNode":"1e3f9070b4a48e6f","toSide":"top"},
		{"id":"579bd320547644a7","fromNode":"659aa2aef7ab051a","fromSide":"top","toNode":"ee2b0a9e9a25acec","toSide":"right","label":"Dead?"},
